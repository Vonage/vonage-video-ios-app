# Development environment for VERA iOS project
# Install direnv: brew install direnv
# Then run: direnv allow

# Add scripts to PATH for easy access
export PATH="./scripts:$PATH"

# Useful aliases
alias build='xcodebuild build -workspace VERA/VERA.xcworkspace -scheme VERA -sdk iphonesimulator'
alias test-core='./scripts/test-core.sh'
alias test-all='./scripts/test.sh'
alias test-ui='./scripts/test.sh -ui'
alias test-snapshots='./scripts/test-snapshots.sh'
alias validate='./scripts/validate-setup.sh'
alias format-check='swift-format --version && echo "Format config: .swift-format"'

# Git LFS helpers
alias lfs-status='git lfs status'
alias lfs-files='git lfs ls-files'
alias lfs-pull='git lfs pull'

echo "🚀 VERA iOS development environment loaded!"
echo "Quick commands: test-core, test-all, test-snapshots, validate"
