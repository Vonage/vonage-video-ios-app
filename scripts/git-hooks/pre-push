#!/bin/bash

echo "🔍 Running code quality checks before push..."

# Get the root directory of the git repository
GIT_ROOT=$(git rev-parse --show-toplevel)

# Check if we're in a git repository
if [ ! -d "$GIT_ROOT/.git" ]; then
    echo "❌ Not in a git repository"
    exit 1
fi

# Change to the git root directory
cd "$GIT_ROOT"

# Check if our code quality script exists
if [ ! -f "scripts/code-quality.sh" ]; then
    echo "❌ scripts/code-quality.sh not found"
    echo "   Make sure you're in the project root and the script exists"
    exit 1
fi

# Run code quality checks (swift-format + SwiftLint)
echo "📊 Running swift-format and SwiftLint..."
echo ""

if scripts/code-quality.sh; then
    echo ""
    echo "✅ All code quality checks passed!"
    echo "� Push allowed"
    exit 0
else
    echo ""
    echo "❌ Code quality checks failed"
    echo ""
    echo "💡 To fix issues automatically, run:"
    echo "   scripts/code-quality.sh --fix"
    echo ""
    echo "� Or fix issues individually:"
    echo "   scripts/code-quality.sh --format-only  # Only swift-format"
    echo "   scripts/code-quality.sh --lint-only    # Only SwiftLint"
    echo ""
    echo "🚫 Push rejected due to code quality issues"
    exit 1
fi