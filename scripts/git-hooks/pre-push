#!/bin/bash

echo "🔍 Running swift-format before push..."

# Get the root directory of the git repository
GIT_ROOT=$(git rev-parse --show-toplevel)
SWIFT_FORMAT_CONFIG="$GIT_ROOT/.swift-format"

# Check if swift-format is installed
if ! command -v swift-format &> /dev/null; then
    echo "❌ swift-format is not installed. Please install it first:"
    echo "   brew install swift-format"
    exit 1
fi

# Check if .swift-format config exists
if [ ! -f "$SWIFT_FORMAT_CONFIG" ]; then
    echo "⚠️  .swift-format config not found at $SWIFT_FORMAT_CONFIG"
    echo "   Using default swift-format configuration"
    SWIFT_FORMAT_CONFIG=""
fi

# Find all Swift files in the project
SWIFT_FILES=$(find . -name "*.swift" \
    -not -path "./build/*" \
    -not -path "./.build/*" \
    -not -path "./DerivedData/*" \
    -not -path "./Pods/*" \
    -not -path "./Carthage/*" \
    -not -path "./vendor/*")

if [ -z "$SWIFT_FILES" ]; then
    echo "✅ No Swift files found to format"
    exit 0
fi

# Run swift-format in verification mode
echo "Checking format for files:"
echo "$SWIFT_FILES" | while read file; do
    echo "  📄 $file"
done

# Check format (does not modify files)
FORMAT_ISSUES=""
FORMAT_DETAILS=""
while IFS= read -r file; do
    if [ -f "$file" ]; then
        # Check if the file would be changed by swift-format
        if [ -n "$SWIFT_FORMAT_CONFIG" ]; then
            DIFF_OUTPUT=$(swift-format format --configuration "$SWIFT_FORMAT_CONFIG" "$file" | diff -u "$file" - 2>/dev/null)
            if [ $? -ne 0 ]; then
                FORMAT_ISSUES="$FORMAT_ISSUES$file needs formatting\n"
                FORMAT_DETAILS="$FORMAT_DETAILS\n📄 $file:\n$DIFF_OUTPUT\n"
            fi
        else
            DIFF_OUTPUT=$(swift-format format "$file" | diff -u "$file" - 2>/dev/null)
            if [ $? -ne 0 ]; then
                FORMAT_ISSUES="$FORMAT_ISSUES$file needs formatting\n"
                FORMAT_DETAILS="$FORMAT_DETAILS\n📄 $file:\n$DIFF_OUTPUT\n"
            fi
        fi
    fi
done <<< "$SWIFT_FILES"

if [ -n "$FORMAT_ISSUES" ]; then
    echo "❌ Format issues found:"
    echo -e "$FORMAT_ISSUES"
    echo ""
    echo "🔍 Detailed differences:"
    echo -e "$FORMAT_DETAILS"
    echo ""
    echo "💡 To fix formatting issues, run:"
    if [ -n "$SWIFT_FORMAT_CONFIG" ]; then
        echo "   find . -name '*.swift' -not -path './build/*' -not -path './.build/*' | xargs swift-format format --in-place --configuration \"$SWIFT_FORMAT_CONFIG\""
    else
        echo "   find . -name '*.swift' -not -path './build/*' -not -path './.build/*' | xargs swift-format format --in-place"
    fi
    echo ""
    echo "🚫 Push rejected due to formatting issues"
    exit 1
fi

echo "✅ All Swift files are properly formatted!"
exit 0